generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  MENTOR
  ADMIN
  EXECUTIVE
}

enum Level {
  PVC // ปวช
  PVS // ปวส
}

enum JobType {
  INSPECT // ตรวจสอบ
  REPAIR // ซ่อมบำรุง
  INSTALL // ติดตั้ง
  WIRING // เดินสาย
  OTHER // อื่นๆ
}

enum SystemCategory {
  LIGHTING // แสงสว่าง
  OUTLET // เต้ารับ/ปลั๊ก
  CONTROL_PANEL // ตู้ควบคุม MDB/DB
  AIRCON // เครื่องปรับอากาศ
  BACKUP_POWER // ระบบสำรองไฟ
  OTHER // อื่นๆ
}

enum ReportStatus {
  PENDING_ASSIGN // รอมอบหมาย
  PENDING_APPROVAL // รออนุมัติ
  APPROVED // อนุมัติ
  REJECTED // ตีกลับ
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(STUDENT)
  level         Level?
  school        String?
  advisor       String? // อาจารย์นิเทศ
  startDate     DateTime? @db.Date
  endDate       DateTime? @db.Date
  profileDone   Boolean   @default(false)

  accounts        Account[]
  sessions        Session[]
  reports         Report[]  @relation("StudentReports")
  mentoredReports Report[]  @relation("MentorReports")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Report {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  title       String
  description String   @db.Text
  tasks       String[] @default([])

  // งานช่างไฟ — อาคารและบริเวณ
  jobType        JobType?
  systemCategory SystemCategory?
  location       String? // อาคาร/ชั้น/บริเวณ
  tools          String[]        @default([])
  ppe            String[]        @default([]) // รายการความปลอดภัยที่ทำ
  learned        String?         @db.Text // ปัญหา/สิ่งที่เรียนรู้

  userId String
  user   User   @relation("StudentReports", fields: [userId], references: [id], onDelete: Cascade)

  assignedMentorId String?
  assignedMentor   User?   @relation("MentorReports", fields: [assignedMentorId], references: [id], onDelete: SetNull)

  status        ReportStatus @default(PENDING_ASSIGN)
  mentorComment String?      @db.Text
  scores        Json? // { skill, safety, responsibility, quality, report } 1-5
  evaluatedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
}
