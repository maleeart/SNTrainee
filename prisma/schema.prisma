generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  MENTOR
  ADMIN
  EXECUTIVE
}

enum Level {
  PVC // ปวช
  PVS // ปวส
}

enum JobType {
  INSPECT // ตรวจสอบ
  REPAIR // ซ่อมบำรุง
  INSTALL // ติดตั้ง
  WIRING // เดินสาย
  OTHER // อื่นๆ
}

enum SystemCategory {
  LIGHTING // แสงสว่าง
  OUTLET // เต้ารับ/ปลั๊ก
  CONTROL_PANEL // ตู้ควบคุม MDB/DB
  AIRCON // เครื่องปรับอากาศ
  BACKUP_POWER // ระบบสำรองไฟ
  OTHER // อื่นๆ
}

enum ReportStatus {
  PENDING  // รอประเมิน
  SCORED   // ประเมินแล้ว (มีพี่เลี้ยงประเมินอย่างน้อย 1 คน)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(STUDENT)
  nickname      String?
  level         Level?
  school        String?
  advisor       String? // อาจารย์นิเทศ
  startDate     DateTime? @db.Date
  endDate       DateTime? @db.Date
  profileDone   Boolean   @default(false)

  accounts    Account[]
  sessions    Session[]
  reports     Report[]     @relation("StudentReports")
  evaluations Evaluation[] @relation("MentorEvaluations")

  announcementsCreated Announcement[]     @relation("AnnouncementAuthor")
  announcementReads    AnnouncementRead[] @relation("AnnouncementReads")

  coursesCreated Course[]         @relation("CourseAuthor")
  lessonProgress LessonProgress[] @relation("LessonProgress")
  quizAttempts   QuizAttempt[]    @relation("QuizAttempts")

  checkIns      CheckIn[]      @relation("CheckIns")
  leaveRequests LeaveRequest[] @relation("LeaveRequests")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Report {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  title       String
  description String   @db.Text
  tasks       String[] @default([])

  jobType        JobType?
  systemCategory SystemCategory?
  location       String?
  tools          String[] @default([])
  ppe            String[] @default([])
  learned        String?  @db.Text
  solution       String?  @db.Text
  result         String?  @db.Text
  images         String[] @default([])
  editReason     String?  @db.Text

  userId String
  user   User   @relation("StudentReports", fields: [userId], references: [id], onDelete: Cascade)

  status ReportStatus @default(PENDING)

  evaluations Evaluation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Announcement {
  id          String   @id @default(cuid())
  title       String
  body        String   @db.Text
  target      String   @default("ALL") // ALL | STUDENT | MENTOR | ADMIN | EXECUTIVE
  pinned      Boolean  @default(false)
  createdAt   DateTime @default(now())
  createdById String
  createdBy   User     @relation("AnnouncementAuthor", fields: [createdById], references: [id])
  reads       AnnouncementRead[]
}

model AnnouncementRead {
  announcementId String
  userId         String
  readAt         DateTime     @default(now())
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User         @relation("AnnouncementReads", fields: [userId], references: [id], onDelete: Cascade)

  @@id([announcementId, userId])
}

model Course {
  id          String         @id @default(cuid())
  title       String
  description String?        @db.Text
  emoji       String         @default("📋")
  order       Int            @default(0)
  createdAt   DateTime       @default(now())
  createdById String
  createdBy   User           @relation("CourseAuthor", fields: [createdById], references: [id])
  lessons     CourseLesson[]
}

model CourseLesson {
  id       String  @id @default(cuid())
  courseId String
  course   Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title    String
  order    Int     @default(0)
  videoUrl String?
  fileUrl  String?
  fileName String?
  quiz     LessonQuiz?
  progress LessonProgress[]
}

model LessonQuiz {
  id        String       @id @default(cuid())
  lessonId  String       @unique
  lesson    CourseLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  passScore Int          @default(70)
  questions Json         // [{q, options:[string,string,string,string], answer:0-3}]
  attempts  QuizAttempt[]
}

model LessonProgress {
  userId      String
  lessonId    String
  completedAt DateTime     @default(now())
  user        User         @relation("LessonProgress", fields: [userId], references: [id], onDelete: Cascade)
  lesson      CourseLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  @@id([userId, lessonId])
}

model QuizAttempt {
  id        String     @id @default(cuid())
  userId    String
  quizId    String
  score     Int
  passed    Boolean
  answers   Json
  createdAt DateTime   @default(now())
  user      User       @relation("QuizAttempts", fields: [userId], references: [id], onDelete: Cascade)
  quiz      LessonQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

model CheckIn {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @db.Date
  createdAt DateTime @default(now())
  user      User     @relation("CheckIns", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model LeaveRequest {
  id        String   @id @default(cuid())
  userId    String
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  reason    String   @db.Text
  createdAt DateTime @default(now())
  user      User     @relation("LeaveRequests", fields: [userId], references: [id], onDelete: Cascade)
}

model Evaluation {
  id       String  @id @default(cuid())
  reportId String
  report   Report  @relation(fields: [reportId], references: [id], onDelete: Cascade)
  mentorId String
  mentor   User    @relation("MentorEvaluations", fields: [mentorId], references: [id])
  scores   Json    // { skill, safety, responsibility, quality, report } 1-5
  comment  String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([reportId, mentorId])
}
